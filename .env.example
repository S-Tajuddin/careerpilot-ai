# ==============================================================
# CareerPilot AI — Personal Career Tool — Environment Variables
# ==============================================================
# Copy this to .env and fill in your values
# NEVER commit .env to git!
# ==============================================================

# --- LLM ---
OLLAMA_HOST=http://localhost:11434
GOOGLE_API_KEY=                          # Get from: https://aistudio.google.com → Create API key

# --- Job Search APIs ---
RAPIDAPI_KEY=                            # Get from: https://rapidapi.com → JSearch → Subscribe (free)
JSEARCH_HOST=jsearch.p.rapidapi.com
ADZUNA_APP_ID=                           # Get from: https://developer.adzuna.com → Create app
ADZUNA_APP_KEY=

# --- Company Research ---
SERPER_API_KEY=                          # Get from: https://serper.dev → Dashboard

# --- Notifications ---
TELEGRAM_BOT_TOKEN=                      # Get from: @BotFather on Telegram → /newbot
TELEGRAM_CHAT_ID=                        # Get from: send msg to bot → https://api.telegram.org/bot<TOKEN>/getUpdates

# --- Google Sheets Sync ---
GOOGLE_SHEETS_CREDENTIALS_FILE=          # Path to service account JSON (optional)
GOOGLE_SHEETS_SPREADSHEET_ID=            # The spreadsheet ID from the URL (optional)

# --- App ---
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=                              # Run: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
DATABASE_PATH=./data/careerpilot.db
